# Standalone-запуск token-server (node server.js без docker).
# Для dev-стека в docker используем infra/.env.dev — здесь пример для прода
# или ручного `node server.js` при разработке backend'а вне контейнера.
#
# Все переменные required. Сервер падает на старте с "Missing env: X",
# если что-то не задано — никаких fallback'ов в коде.
#
#   cp .env.example .env
#   node server.js

PORT=4000

# URL, который выдаётся клиентам в /session/create ответе.
LIVEKIT_URL=wss://livekit.example.com

# Куда сам backend ходит за RoomServiceClient (deleteRoom и т.п.).
# В проде обычно = LIVEKIT_URL с ws→http (wss://a → https://a).
# В dev другой, потому что backend в docker, а LiveKit слушает на хосте.
LIVEKIT_INTERNAL_URL=https://livekit.example.com

LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=replace_with_openssl_rand_base64_32
REDIS_URL=redis://127.0.0.1:6379

# CORS. Форматы:
#   '*'                    — разрешить всем (для quick tests, НЕ для прода)
#   'dev'                  — любой http://localhost:* и http://127.0.0.1:*
#   'https://a.com'        — один origin
#   'https://a,https://b'  — несколько через запятую
CORS_ORIGIN=https://agent.cobrowse.example.com

LOG_LEVEL=info
