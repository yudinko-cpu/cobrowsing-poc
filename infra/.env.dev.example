# Локальный dev-стек. Скопировать в .env.dev.
#
#   cp .env.dev.example .env.dev
#
# Затем:
#   docker compose -f docker-compose.dev.yml --env-file .env.dev up -d

# Ключи для LiveKit. В dev можно оставить фиксированные значения — этот
# стек слушает только 127.0.0.1, наружу ничего не торчит.
# ВАЖНО: те же значения должны быть в livekit.dev.yaml (секция keys).
LIVEKIT_API_KEY=APIdevkeydevkey
LIVEKIT_API_SECRET=devsecret_at_least_32_chars_replace_before_commit_pls
