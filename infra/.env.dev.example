# Единый источник конфига для локального dev-стека.
#
#   cp .env.dev.example .env.dev
#   docker compose -f docker-compose.dev.yml up -d --build
#
# .env.dev автоматически подхватывается docker compose из этой же директории —
# и как источник переменных для ${VAR} интерполяции в compose-файле,
# и через env_file: для token-server.
#
# ВСЕ адреса и порты стека живут ЗДЕСЬ. Хочешь поменять порт или host — правишь
# один файл, а не бегаешь по docker-compose / server.js / .env.local.

# ─── LiveKit auth ─────────────────────────────────────────────────────────────
# В dev можно оставить фиксированные значения — стек слушает только 127.0.0.1.
# ВАЖНО: те же значения дублируются в livekit.dev.yaml → keys: (пока не
# автоматизировано, при смене — синхронизируй руками).
LIVEKIT_API_KEY=APIdevkeydevkey
LIVEKIT_API_SECRET=devsecret_at_least_32_chars_replace_before_commit_pls

# ─── Host / network ──────────────────────────────────────────────────────────
# HOST_IP — куда ходят КЛИЕНТЫ (браузер, iOS Simulator, реальный iPhone).
# Backend внутри контейнера ходит на LiveKit/Redis через host.docker.internal —
# это отдельная тема, HOST_IP на неё не влияет.
#
# Значения:
#   127.0.0.1        Simulator + браузер на том же Mac. Дефолт.
#   192.168.x.y      Реальный iPhone в той же Wi-Fi. Узнать: `ipconfig getifaddr en0`.
HOST_IP=127.0.0.1

# ─── Ports ───────────────────────────────────────────────────────────────────
# Меняй только при конфликте с чем-то другим на машине.
TOKEN_SERVER_PORT=4000
WEB_AGENT_PORT=3000
LIVEKIT_SIGNAL_PORT=7880
LIVEKIT_TCP_PORT=7881
REDIS_PORT=6379

# ─── CORS ────────────────────────────────────────────────────────────────────
# 'dev' — разрешить любой http://localhost:* и http://127.0.0.1:*
# Для прода: список origins через запятую, например https://agent.example.com
CORS_ORIGIN=dev

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
