# Скопировать в .env и заполнить значениями для своего сервера.

# Публичный IP сервера (на нём слушает LiveKit)
PUBLIC_IP=203.0.113.10

# Домены (должны указывать DNS A-записями на PUBLIC_IP)
DOMAIN=livekit.example.com
API_DOMAIN=api.cobrowse.example.com
AGENT_DOMAIN=agent.cobrowse.example.com

# LiveKit ключи (см. infra/README.md как сгенерировать)
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=replace_with_openssl_rand_base64_32
