# Prod env для infra/docker-compose.yml.
# На VPS: cp .env.example .env && $EDITOR .env
#
# Все переменные обязательные. server.js — required-only (fail-fast),
# LiveKit --node-ip требует PUBLIC_IP, Caddy падает без доменов.

# --- Сеть ---
# Публичный IPv4 VPS. Передаётся LiveKit через --node-ip, LiveKit кладёт его
# в ICE-кандидаты для SDP.
PUBLIC_IP=203.0.113.10

# --- Домены (должны иметь A-записи на PUBLIC_IP) ---
DOMAIN=livekit.example.com
API_DOMAIN=api.cobrowse.example.com
AGENT_DOMAIN=agent.cobrowse.example.com

# --- LiveKit ключи ---
# Сгенерировать:
#   LIVEKIT_API_KEY="API$(openssl rand -hex 8)"
#   LIVEKIT_API_SECRET="$(openssl rand -base64 32)"
# Синхронизировать с infra/livekit.yaml секцией keys: (пока вручную).
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=replace_with_openssl_rand_base64_32_chars_min

# --- GHCR ---
# Owner GHCR-репо (GitHub username или организация в нижнем регистре).
# Образы: ghcr.io/${GHCR_OWNER}/cobrowsing-poc-backend, /...-web-agent
GHCR_OWNER=your-github-username

# Тег образа. GHA переписывает его на git SHA при деплое.
# Первый ручной старт до первого GHA-деплоя — оставить latest.
IMAGE_TAG=latest
