# Caddy reverse proxy + auto-TLS через Let's Encrypt.
# Три хоста: LiveKit signaling, token API, web-agent (Next.js SSR).
#
# Caddy сам поднимает ACME challenge на :80 и получает сертификаты для всех
# трёх доменов. DNS A-записи должны быть настроены ДО первого старта, иначе
# challenge не пройдёт и в логах будет цикл retry.
#
# Caddy в host mode → апстримы адресуются через localhost:
#   - LiveKit (host mode) — localhost:7880
#   - backend (bridge, published) — 127.0.0.1:4000
#   - web-agent (bridge, published) — 127.0.0.1:3000

# LiveKit WebSocket signaling.
{$DOMAIN} {
    reverse_proxy localhost:7880

    log {
        output file /data/livekit-access.log
        format json
    }
}

# Token API.
{$API_DOMAIN} {
    reverse_proxy localhost:4000

    log {
        output file /data/api-access.log
        format json
    }
}

# Web-agent (Next.js SSR — reverse_proxy, не file_server).
{$AGENT_DOMAIN} {
    reverse_proxy localhost:3000

    log {
        output file /data/agent-access.log
        format json
    }
}
