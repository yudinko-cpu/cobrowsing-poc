# Скопировать в web-agent/.env.local и подставить свои значения.
# ВАЖНО: Next.js читает NEXT_PUBLIC_* только на старте dev-сервера.
# После правки .env.local — перезапустить `npm run dev`, hot reload не подхватит.

# URL token-server backend'а.
# Dev (docker compose dev-стек):   http://127.0.0.1:4000
# Prod:                            https://api.cobrowse.example.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
