# перекрываются anonymous volumes в docker-compose.dev.yml,
# но без этого файла COPY . . залил бы гигабайты в image layer.
node_modules
.next
.env
.env.*
!.env.local.example
npm-debug.log*
.git
.gitignore
Dockerfile*
.dockerignore
README.md
